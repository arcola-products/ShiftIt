{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Archive": {
    "ScanIntervalMinutes": 60,
    "MinAgeDays": 30,
    "RemoveEmptyHotFolders": true,
    "VerifyWithHash": false,
    "Pairs": [
      {
        "Name": "Reports",
        "HotRoot": "D:\\Hot\\Reports",
        "ArchiveRoot": "E:\\Archive\\Reports"
      },
      {
        "Name": "Logs",
        "HotRoot": "D:\\Hot\\Logs",
        "ArchiveRoot": "\\\\nas\\archive\\Logs"
      }
    ]
  }
}
