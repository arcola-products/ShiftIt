{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "ShiftIt": "Debug",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "LogLevel": {
        "Default": "Information",
        "ShiftIt": "Information"
      }
    },
    "EventLog": {
      "LogLevel": {
        "Default": "Warning",
        "ShiftIt": "Warning",
        "ShiftIt.Worker": "Information",
        "ShiftIt.Services.ArchiveScanner": "Information",
        "ShiftIt.Services.FileMover": "None"
      }
    }
  },
  "Archive": {
    "ScanIntervalMinutes": 60,
    "MinAgeDays": 30,
    "RemoveEmptyHotFolders": true,
    "VerifyWithHash": false,
    "MaxRetries": 3,
    "RetryDelaySeconds": 2,
    "LogDirectory": "logs",
    "LogRetentionDays": 14,
    "Pairs": [
      {
        "Name": "Reports",
        "HotRoot": "D:\\Hot\\Reports",
        "ArchiveRoot": "E:\\Archive\\Reports"
      },
      {
        "Name": "Logs",
        "HotRoot": "D:\\Hot\\Logs",
        "ArchiveRoot": "\\\\nas\\archive\\Logs"
      }
    ]
  }
}
